{
  "name": "license-compliance-enforcer",
  "version": "2.0.0",
  "description": "Free, advanced license compliance enforcement for every ecosystem. Blocks non-compliant dependencies before they hit production.",
  "main": "src/index.js",
  "bin": {
    "lce": "src/cli/index.js",
    "license-compliance-enforcer": "src/cli/index.js"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "build:dashboard": "cd dashboard && npm run build",
    "docs": "jsdoc src/ -r -d docs/api",
    "release": "standard-version",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "license",
    "compliance",
    "open-source",
    "sbom",
    "spdx",
    "cyclonedx",
    "github-action",
    "security",
    "dependency",
    "audit",
    "gpl",
    "mit",
    "apache",
    "legal",
    "npm",
    "pip",
    "cargo",
    "go",
    "maven"
  ],
  "author": {
    "name": "license-compliance-enforcer contributors",
    "url": "https://github.com/your-org/license-compliance-enforcer"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/license-compliance-enforcer.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/license-compliance-enforcer/issues"
  },
  "homepage": "https://github.com/your-org/license-compliance-enforcer#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.0",
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "ora": "^7.0.1",
    "semver": "^7.5.4",
    "table": "^6.8.1",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "standard-version": "^9.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/cli/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  }
}
